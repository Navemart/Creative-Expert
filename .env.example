# -----------------------------------------------------------------------------
# Environment variables — copy this file to `.env` and fill in your own values.
#
#   cp .env.example .env
#
# Anything prefixed with VITE_ is exposed to the browser by Vite.
# Anything else is server-only (Express reads it via dotenv).
# -----------------------------------------------------------------------------

# Port the Express server listens on (also what Vite proxies /api requests to).
PORT=3001

# Clerk — sign up at https://clerk.com and paste your publishable key here.
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase — create a project at https://supabase.com and paste your URL + anon key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Supabase JWT Secret — found in Supabase → Settings → API → JWT Secret
# This is used by the Express server to mint Supabase-compatible JWTs for RLS.
SUPABASE_JWT_SECRET=

# Instagram (Meta) — create a Meta App at https://developers.facebook.com
# Product: "Instagram" → "Instagram API with Instagram Login"
# INSTAGRAM_REDIRECT_URI must be registered in the Meta App's "Valid OAuth Redirect URIs"
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/instagram/callback

# Frontend URL — used by the server to redirect back after OAuth
# Dev:  http://localhost:5173
# Prod: https://yourdomain.com
APP_URL=http://localhost:5173

# Zoom — Server-to-Server OAuth app from https://marketplace.zoom.us
# Create an app: "Server-to-Server OAuth" → copy the Account ID, Client ID, Client Secret
# Required scopes: recording:read:admin (or recording:read)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Notion Integration Token — auto-fetches meeting summaries from Notion
# 1. Go to: https://www.notion.so/my-integrations → New integration → copy token
# 2. Share your "סיכום שיחות" Notion page with the integration
# Once set: clicking "סיכום AI" auto-pulls from Notion; nightly cron syncs all new recordings
NOTION_TOKEN=

# Clerk Secret Key — for admin panel to list all users
# Clerk Dashboard → API Keys → Secret keys → copy sk_test_...
CLERK_SECRET_KEY=

# (Optional) Admin user ID — show admin-only pages in the sidebar
VITE_ADMIN_USER_ID=
